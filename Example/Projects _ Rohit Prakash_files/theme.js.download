let determineComputedTheme=()=>document.documentElement.getAttribute("data-theme")||"light",determineThemeSetting=()=>"light",toggleThemeSetting=()=>{},setThemeSetting=()=>{},setGiscusTheme=e=>{const t=document.querySelector("iframe.giscus-frame");t&&t.contentWindow.postMessage({giscus:{setConfig:{theme:e}}},"https://giscus.app")},applyTheme=()=>{const e=determineComputedTheme(),t=document.getElementById("highlight_theme_light");t&&(t.media=""),document.querySelectorAll("table").forEach(e=>e.classList.remove("table-dark")),setGiscusTheme(e),"undefined"!=typeof medium_zoom&&medium_zoom.update({background:getComputedStyle(document.documentElement).getPropertyValue("--global-bg-color")+"ee"})},initTheme=()=>applyTheme();